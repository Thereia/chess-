<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="thereia.java.chess.client.LoginController"
            prefWidth="400" prefHeight="450">
    
    <fx:define>
        <ToggleGroup fx:id="authToggleGroup"/>
    </fx:define>
    
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: linear-gradient(to right, #ff9800, #ffc107);">
            <padding>
                <Insets top="30" right="0" bottom="20" left="0"/>
            </padding>
            <Label text="揭棋对弈">
                <font>
                    <Font name="KaiTi" size="36"/>
                </font>
                <style>
                    -fx-text-fill: white;
                    -fx-font-weight: bold;
                </style>
            </Label>
            <Label text="Jieqi Chess" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 14px; -fx-padding: 5 0 0 0;"/>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="20" style="-fx-background-color: #f5f5f5;">
            <padding>
                <Insets top="10" right="40" bottom="10" left="40"/>
            </padding>
            
            <HBox spacing="0" style="-fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 4, 0, 0, 2);">
                <RadioButton fx:id="loginRadio" text="登录" toggleGroup="$authToggleGroup" selected="true"
                        style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-padding: 12 24; -fx-border-radius: 8 0 0 8; -fx-border-color: transparent; -fx-mark-color: #ff9800;"/>
                <RadioButton fx:id="registerRadio" text="注册" toggleGroup="$authToggleGroup"
                        style="-fx-background-color: transparent; -fx-text-fill: #666; -fx-font-weight: bold; -fx-font-size: 15px; -fx-padding: 12 24; -fx-border-radius: 0 8 8 0; -fx-border-color: transparent;"/>
            </HBox>
            
            <TextField fx:id="userIdField" promptText="用户名" prefWidth="320"
                       style="-fx-background-color: white; -fx-border-color: #eee; -fx-border-width: 2px; -fx-border-radius: 8; -fx-padding: 12; -fx-font-size: 15px;"/>
            <PasswordField fx:id="passwordField" promptText="密码" prefWidth="320"
                           style="-fx-background-color: white; -fx-border-color: #eee; -fx-border-width: 2px; -fx-border-radius: 8; -fx-padding: 12; -fx-font-size: 15px;"/>
            <TextField fx:id="nickNameField" promptText="昵称（注册时填写）" prefWidth="320"
                       style="-fx-background-color: white; -fx-border-color: #eee; -fx-border-width: 2px; -fx-border-radius: 8; -fx-padding: 12; -fx-font-size: 15px;"/>
            
            <Button fx:id="authButton" text="登录" prefWidth="320" onAction="#handleAuth"
                    style="-fx-background-color: linear-gradient(to right, #ff9800, #ffc107); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 14; -fx-border-radius: 8;"/>
            
            <Label fx:id="statusLabel" text="" style="-fx-text-alignment: center; -fx-min-height: 24px;"/>
        </VBox>
    </center>
    
    <bottom>
        <VBox spacing="10" style="-fx-background-color: white;">
            <padding>
                <Insets top="15" right="40" bottom="25" left="40"/>
            </padding>
            <TextField fx:id="serverUrlField" promptText="WebSocket地址" text="ws://localhost:8887/ws" prefWidth="320"
                       style="-fx-background-color: #f8f8f8; -fx-border-color: #ddd; -fx-border-width: 1px; -fx-border-radius: 6; -fx-padding: 10; -fx-font-size: 14px;"/>
            <Button fx:id="connectButton" text="连接服务器" prefWidth="320" onAction="#handleConnect"
                    style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-padding: 12; -fx-border-radius: 6;"/>
        </VBox>
    </bottom>
</BorderPane>